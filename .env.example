# Environment Configuration Example
# Copy this file to .env and update with your actual values

# ── SERVER CONFIGURATION ──
PORT=3000
NODE_ENV=development  # Set to 'production' on Render
SESSION_SECRET=your_long_random_session_secret_here

# ── DATABASE CONFIGURATION ──
# Local SQLite Path (Used if DATABASE_URL is not set)
DATABASE_PATH=./sec2_gr14_ws_src/data/sec2_gr14_database.sqlite

# Production PostgreSQL URL (Use Render's Internal/External DB URL)
# DATABASE_URL=postgres://user:password@hostname:port/database

# ── SECURITY & OPTIONAL ──
# CORS_ORIGIN=http://localhost:5000
# FORCE_SEED=false  # Set to 'true' once to force a wipe/re-seed on production
JWT_SECRET=your_long_random_jwt_secret_here
API_TIMEOUT=5000
